*.out
*.history
*.png
*.des
*.vspgeom
*.vkey
*.quad.cases
*.quad.1.dat
*.lod
*.slc
*.cuts
*.csf
*.cases

# Whitelist baseline reference files required to run
*.vsp3
*.vspaero
!system_files/altc130mod.vsp3
!system_files/altc130mod.vspaero
